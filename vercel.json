{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/index.html", "dest": "/index.html" },
    { "src": "/success.html", "dest": "/success.html" },
    { "src": "/api.html", "dest": "/api.html" },
    { "src": "/bulk.html", "dest": "/bulk.html" },
    { "src": "/watchlist.html", "dest": "/watchlist.html" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/success", "dest": "/success.html" }
  ]
}